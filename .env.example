# Notifuse Environment Configuration
# 复制此文件为 .env 并填写实际值

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Secret key for encrypting sensitive data (使用 openssl rand -base64 64 生成)
SECRET_KEY=your-secret-key-here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=notifuse_system
DB_SSLMODE=disable

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

SERVER_PORT=8080
SERVER_HOST=127.0.0.1
ENVIRONMENT=production
LOG_LEVEL=info

# CORS - Allow all origins for development
CORS_ALLOW_ORIGIN=*

# =============================================================================
# OPTIONAL - Can be configured via Setup Wizard
# =============================================================================

# Root administrator email
ROOT_EMAIL=your-email@example.com

# API Endpoint - Must use HTTPS for production
API_ENDPOINT=https://your-domain.com

# SMTP Configuration (configure via wizard)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=

# Telemetry
TELEMETRY=false
CHECK_FOR_UPDATES=false
